{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://script.google.com/macros/s/AKfycbxHAmzaTSeAal82t6ICiOG93qURxI2tTWu_F51uZCuFolQgcsrt6DP5uc4q7X-Bqsc7/exec?action=sitemap"
    },
    { "source": "/artikel", "destination": "/artikel.html" },
    { "source": "/",        "destination": "/index.html"   }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
